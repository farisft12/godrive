# GoDrive Backend - Environment Variables
# Copy to .env and set values

# Server
NODE_ENV=development
PORT=3000

# PostgreSQL
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=godrive
PG_USER=postgres
PG_PASSWORD=postgres
PG_POOL_MAX=20

# Redis (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# Set to true if Redis is not installed (app runs without background jobs)
REDIS_SKIP=true
# Or use single URL:
# REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars

# File storage (default: backend/storage)
STORAGE_ROOT=./storage

# File encryption at rest (optional but recommended; min 32 chars)
FILE_ENCRYPTION_KEY=your-32-char-or-longer-encryption-key!!

# Upload limit (MB)
MAX_UPLOAD_MB=500

# Rate limits
RATE_LIMIT_AUTH=20
RATE_LIMIT_API=200

# CORS (comma-separated or * for all)
CORS_ORIGIN=*

# Fonnte (WhatsApp) - for sending verification code on register
FOONTE_URL=https://api.fonnte.com
FOONTE_TOKEN=your-fonnte-api-token

# Run BullMQ workers in same process (set to true to process compression/video jobs)
RUN_WORKERS=false

# QRIS Dynamic (checkout)
# Set to your full static QRIS string; app will convert to dynamic with order amount using CRC16-CCITT.
# Get the string by scanning your static QR with an app that shows raw payload, or use a QRIS decoder.
# STATIC_QRIS_PAYLOAD=00020101021126610014ID1025453509719...
