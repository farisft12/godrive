# GoDrive Docker - Environment Variables
# Copy to docker/.env and set values before: docker-compose up -d
# PostgreSQL runs on host (Laragon); do NOT set DB_HOST to localhost inside Docker.

# PostgreSQL (on host - Laragon)
DB_HOST=host.docker.internal
DB_PORT=5432
DB_DATABASE=gdrive
DB_USERNAME=postgres
DB_PASSWORD=yourpassword

# JWT (use a strong secret in production)
JWT_SECRET=godrive_secret

# Optional: override defaults
# PG_POOL_MAX=20
# MAX_UPLOAD_MB=500
# CORS_ORIGIN=/
