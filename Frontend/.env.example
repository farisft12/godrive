# GoDrive Frontend - Environment Variables
# Create .env in frontend/ and set:

# Backend API base URL. Empty = use Vite proxy (chunk size must be 1 MB to avoid 413). Set to http://localhost:3001 to call API directly and use larger chunks (Backend CHUNK_SIZE_MB=5 or 10).
VITE_API_URL=

# Backend port for chunk upload when VITE_API_URL is empty (dev only). Must match Backend .env PORT (default 3001). Use 3000 if your backend runs on port 3000.
# VITE_BACKEND_PORT=3001
